{'cells': [{'cell_type': 'markdown', 'metadata': {}, 'source': ['# Notebook 02: Feature Extraction avec ResNet\n', '\n', "Ce notebook démontre l'extraction de features à partir d'images IRM cérébrales en utilisant différents modèles pré-entraînés.\n", '\n', '## Objectifs\n', '1. Charger et pré-traiter les images IRM\n', '2. Extraire des features avec ResNet50, VGG16 et DenseNet\n', '3. Visualiser les embeddings dans un espace réduit\n', '4. Préparer les données pour le clustering\n', '5. Comparer les performances des différents modèles']}, {'cell_type': 'code', 'execution_count': None, 'metadata': {}, 'outputs': [], 'source': ['# Importations\n', 'import sys\n', 'import os\n', "sys.path.append('..')\n", '\n', 'import numpy as np\n', 'import pandas as pd\n', 'import matplotlib.pyplot as plt\n', 'import seaborn as sns\n', 'from pathlib import Path\n', 'import torch\n', 'import torchvision.transforms as transforms\n', 'import torchvision.models as models\n', 'from PIL import Image\n', '\n', '# Scikit-learn\n', 'from sklearn.decomposition import PCA\n', 'from sklearn.manifold import TSNE\n', 'from sklearn.metrics.pairwise import cosine_similarity\n', 'from sklearn.preprocessing import StandardScaler\n', 'from sklearn.cluster import KMeans\n', 'from sklearn.metrics import silhouette_score, davies_bouldin_score, adjusted_rand_score\n', '\n', '# Visualisation\n', 'import plotly.express as px\n', 'import plotly.graph_objects as go\n', 'from plotly.subplots import make_subplots']}, {'cell_type': 'markdown', 'metadata': {}, 'source': ['## 1. Configuration et chargement des données']}, {'cell_type': 'code', 'execution_count': None, 'metadata': {}, 'outputs': [], 'source': ['# Configuration\n', 'DATA_DIR = Path("../data")\n', 'RESULTS_DIR = Path("../results")\n', 'RESULTS_DIR.mkdir(exist_ok=True)\n', '\n', 'DEVICE = "cuda" if torch.cuda.is_available() else "cpu"\n', 'BATCH_SIZE = 32\n', '\n', 'print(f"Device: {DEVICE}")']}, {'cell_type': 'code', 'execution_count': None, 'metadata': {}, 'outputs': [], 'source': ['# Fonction pour charger les images\n', 'def load_image_paths(data_dir, max_images=None):\n', '    """\n', '    Charge les chemins des images depuis les répertoires data/avec_labels et data/sans_label.\n', '    """\n', '    image_paths = []\n', '    \n', '    # Chargement des images avec labels\n', '    normal_dir = data_dir / "avec_labels" / "normal"\n', '    cancer_dir = data_dir / "avec_labels" / "cancer"\n', '    \n', '    if normal_dir.exists():\n', '        normal_images = list(normal_dir.glob("*.jpg"))\n', '        image_paths.extend(normal_images)\n', '        print(f"Chargé {len(normal_images)} images normales")\n', '    \n', '    if cancer_dir.exists():\n', '        cancer_images = list(cancer_dir.glob("*.jpg"))\n', '        image_paths.extend(cancer_images)\n', '        print(f"Chargé {len(cancer_images)} images avec cancer")\n', '    \n', '    # Chargement des images sans labels\n', '    sans_label_dir = data_dir / "sans_label"\n', '    if sans_label_dir.exists():\n', '        sans_label_images = list(sans_label_dir.glob("*.jpg"))\n', '        image_paths.extend(sans_label_images)\n', '        print(f"Chargé {len(sans_label_images)} images sans label")\n', '    \n', '    # Limiter à un sous-ensemble si nécessaire\n', '    if max_images and len(image_paths) > max_images:\n', '        import random\n', '        image_paths = random.sample(image_paths, max_images)\n', '        print(f"Utilisation d\'un sous-ensemble de {len(image_paths)} images pour les tests")\n', '    \n', '    return image_paths\n', '\n', '# Chargement des images\n', 'image_paths = load_image_paths(DATA_DIR, max_images=100)\n', 'print(f"Nombre total d\'images chargées: {len(image_paths)}")']}, {'cell_type': 'markdown', 'metadata': {}, 'source': ['## 2. Pré-traitement des images']}, {'cell_type': 'code', 'execution_count': None, 'metadata': {}, 'outputs': [], 'source': ['# Transformations pour les modèles pré-entraînés\n', 'transform = transforms.Compose([\n', "    transforms.Resize((224, 224)),  # Taille d'entrée standard\n", '    transforms.ToTensor(),\n', '    transforms.Normalize(mean=[0.485, 0.456, 0.406],  # ImageNet stats\n', '                         std=[0.229, 0.224, 0.225])\n', '])\n', '\n', '# Dataset personnalisé pour les IRM\n', 'class MRIDataset(torch.utils.data.Dataset):\n', '    def __init__(self, image_paths, transform=None):\n', '        self.image_paths = image_paths\n', '        self.transform = transform\n', '        \n', '    def __len__(self):\n', '        return len(self.image_paths)\n', '    \n', '    def __getitem__(self, idx):\n', "        # Charger l'image\n", '        image_path = self.image_paths[idx]\n', "        image = Image.open(image_path).convert('RGB')\n", '        \n', '        if self.transform:\n', '            image = self.transform(image)\n', '            \n', '        return image']}, {'cell_type': 'markdown', 'metadata': {}, 'source': ['## 3. Extraction de features avec différents modèles']}, {'cell_type': 'code', 'execution_count': None, 'metadata': {}, 'outputs': [], 'source': ["# Classe pour l'extraction de features avec différents modèles\n", 'class MultiModelFeatureExtractor:\n', '    def __init__(self, device="cpu"):\n', '        self.device = device\n', '        self.models = {}\n', '        self.feature_dims = {}\n', '        \n', '    def load_model(self, model_name):\n', '        """\n', "        Charge un modèle pré-entraîné et le prépare pour l'extraction de features.\n", '        """\n', '        if model_name == "resnet50":\n', '            model = models.resnet50(pretrained=True)\n', "            # Retirer la dernière couche pour l'extraction de features\n", '            feature_extractor = torch.nn.Sequential(*list(model.children())[:-1])\n', '            feature_dim = 2048\n', '        elif model_name == "vgg16":\n', '            model = models.vgg16(pretrained=True)\n', "            # Retirer la dernière couche pour l'extraction de features\n", '            feature_extractor = torch.nn.Sequential(*list(model.features.children()))\n', "            # Ajouter l'adaptive average pooling\n", '            feature_extractor = torch.nn.Sequential(\n', '                feature_extractor,\n', '                torch.nn.AdaptiveAvgPool2d((1, 1))\n', '            )\n', '            feature_dim = 512\n', '        elif model_name == "densenet":\n', '            model = models.densenet121(pretrained=True)\n', "            # Retirer le classifieur pour l'extraction de features\n", '            feature_extractor = torch.nn.Sequential(\n', '                model.features,\n', '                torch.nn.ReLU(inplace=True),\n', '                torch.nn.AdaptiveAvgPool2d((1, 1))\n', '            )\n', '            feature_dim = 1024\n', '        else:\n', '            raise ValueError(f"Modèle non supporté: {model_name}")\n', '        \n', '        feature_extractor = feature_extractor.to(self.device)\n', '        feature_extractor.eval()\n', '        \n', '        self.models[model_name] = feature_extractor\n', '        self.feature_dims[model_name] = feature_dim\n', '        \n', '        print(f"Modèle {model_name} chargé avec dimension de features: {feature_dim}")\n', '        \n', '    def extract_features(self, model_name, images):\n', '        """\n', "        Extrait les features d'un batch d'images avec un modèle spécifique.\n", '        """\n', '        if model_name not in self.models:\n', '            self.load_model(model_name)\n', '            \n', '        model = self.models[model_name]\n', '        \n', '        with torch.no_grad():\n', '            images = images.to(self.device)\n', '            features = model(images)\n', '            features = features.view(features.size(0), -1)\n', '            return features.cpu().numpy()\n', '    \n', '    def extract_features_from_dataset(self, model_name, dataset, batch_size=32):\n', '        """\n', '        Extrait les features de tout le dataset avec un modèle spécifique.\n', '        """\n', '        if model_name not in self.models:\n', '            self.load_model(model_name)\n', '            \n', '        dataloader = torch.utils.data.DataLoader(dataset, batch_size=batch_size, shuffle=False)\n', '        all_features = []\n', '        \n', '        with torch.no_grad():\n', '            for batch in dataloader:\n', '                batch_features = self.extract_features(model_name, batch)\n', '                all_features.append(batch_features)\n', '                \n', '        return np.vstack(all_features)']}, {'cell_type': 'code', 'execution_count': None, 'metadata': {}, 'outputs': [], 'source': ["# Initialisation de l'extracteur de features\n", 'feature_extractor = MultiModelFeatureExtractor(device=DEVICE)\n', '\n', '# Création du dataset\n', 'dataset = MRIDataset(image_paths, transform=transform)\n', 'print(f"Dataset créé avec {len(dataset)} images")']}, {'cell_type': 'code', 'execution_count': None, 'metadata': {}, 'outputs': [], 'source': ['# Extraction des features avec différents modèles\n', 'models_to_test = ["resnet50", "vgg16", "densenet"]\n', 'features_dict = {}\n', '\n', 'print("Début de l\'extraction des features...")\n', 'for model_name in models_to_test:\n', '    print(f"Extraction des features avec {model_name}...")\n', '    features = feature_extractor.extract_features_from_dataset(model_name, dataset, BATCH_SIZE)\n', '    features_dict[model_name] = features\n', '    print(f"Shape des features {model_name}: {features.shape}")\n', '    \n', '    # Sauvegarde des features\n', '    features_path = RESULTS_DIR / f"features_{model_name}.npy"\n', '    np.save(features_path, features)\n', '    print(f"Features {model_name} sauvegardées dans: {features_path}")']}, {'cell_type': 'markdown', 'metadata': {}, 'source': ['## 4. Analyse statistique des features']}, {'cell_type': 'code', 'execution_count': None, 'metadata': {}, 'outputs': [], 'source': ["# Fonction pour l'analyse statistique des features\n", 'def analyze_features(features, model_name):\n', '    """\n', '    Analyse statistique des features extraites.\n', '    """\n', '    print(f"\\n=== Analyse des features {model_name} ===")\n', '    \n', '    # Statistiques descriptives\n', '    features_df = pd.DataFrame(features)\n', "    stats = features_df.describe().T[['mean', 'std', 'min', 'max']]\n", '    \n', '    print(f"Moyenne globale: {stats[\'mean\'].mean():.4f}")\n', '    print(f"Écart-type moyen: {stats[\'std\'].mean():.4f}")\n', '    print(f"Valeur min globale: {stats[\'min\'].min():.4f}")\n', '    print(f"Valeur max globale: {stats[\'max\'].max():.4f}")\n', '    \n', '    # Distribution des statistiques\n', '    fig, axes = plt.subplots(2, 2, figsize=(12, 10))\n', '    \n', "    axes[0, 0].hist(stats['mean'], bins=30, alpha=0.7, color='skyblue', edgecolor='black')\n", '    axes[0, 0].set_title(f"Distribution des moyennes ({model_name})")\n', '    axes[0, 0].set_xlabel("Moyenne")\n', '    axes[0, 0].set_ylabel("Fréquence")\n', '    \n', "    axes[0, 1].hist(stats['std'], bins=30, alpha=0.7, color='lightcoral', edgecolor='black')\n", '    axes[0, 1].set_title(f"Distribution des écarts-types ({model_name})")\n', '    axes[0, 1].set_xlabel("Écart-type")\n', '    axes[0, 1].set_ylabel("Fréquence")\n', '    \n', "    axes[1, 0].hist(stats['min'], bins=30, alpha=0.7, color='lightgreen', edgecolor='black')\n", '    axes[1, 0].set_title(f"Distribution des minimums ({model_name})")\n', '    axes[1, 0].set_xlabel("Minimum")\n', '    axes[1, 0].set_ylabel("Fréquence")\n', '    \n', "    axes[1, 1].hist(stats['max'], bins=30, alpha=0.7, color='orange', edgecolor='black')\n", '    axes[1, 1].set_title(f"Distribution des maximums ({model_name})")\n', '    axes[1, 1].set_xlabel("Maximum")\n', '    axes[1, 1].set_ylabel("Fréquence")\n', '    \n', '    plt.tight_layout()\n', '    plt.show()\n', '    \n', '    return stats\n', '\n', '# Analyse des features pour chaque modèle\n', 'stats_dict = {}\n', 'for model_name, features in features_dict.items():\n', '    stats_dict[model_name] = analyze_features(features, model_name)']}, {'cell_type': 'markdown', 'metadata': {}, 'source': ['## 5. Réduction de dimensionnalité pour visualisation']}, {'cell_type': 'code', 'execution_count': None, 'metadata': {}, 'outputs': [], 'source': ['# Fonction pour la réduction de dimensionnalité\n', 'def reduce_dimensions(features, method="pca", n_components=2):\n', '    """\n', '    Réduit les dimensions des features pour la visualisation.\n', '    """\n', '    # Standardisation\n', '    scaler = StandardScaler()\n', '    features_scaled = scaler.fit_transform(features)\n', '    \n', '    if method == "pca":\n', '        reducer = PCA(n_components=n_components, random_state=42)\n', '    elif method == "tsne":\n', '        reducer = TSNE(n_components=n_components, random_state=42, perplexity=min(30, len(features)-1))\n', '    else:\n', '        raise ValueError(f"Méthode non supportée: {method}")\n', '        \n', '    reduced_features = reducer.fit_transform(features_scaled)\n', '    \n', '    if method == "pca":\n', '        print(f"Variance expliquée par PCA: {reducer.explained_variance_ratio_.sum():.2%}")\n', '        \n', '    return reduced_features, reducer\n', '\n', '# Réduction de dimensionnalité pour chaque modèle\n', 'reduced_features_dict = {}\n', 'for model_name, features in features_dict.items():\n', '    print(f"\\nRéduction de dimensionnalité pour {model_name}...")\n', '    \n', '    # PCA\n', '    features_pca, pca = reduce_dimensions(features, method="pca", n_components=2)\n', '    \n', '    # t-SNE\n', '    features_tsne, tsne = reduce_dimensions(features, method="tsne", n_components=2)\n', '    \n', '    reduced_features_dict[model_name] = {\n', "        'pca': features_pca,\n", "        'tsne': features_tsne,\n", "        'pca_model': pca,\n", "        'tsne_model': tsne\n", '    }']}, {'cell_type': 'code', 'execution_count': None, 'metadata': {}, 'outputs': [], 'source': ['# Visualisation des features réduites\n', 'def visualize_features(reduced_features_dict):\n', '    """\n', '    Visualise les features réduites pour tous les modèles.\n', '    """\n', '    n_models = len(reduced_features_dict)\n', '    \n', '    # Visualisation PCA\n', '    fig, axes = plt.subplots(n_models, 2, figsize=(15, 5*n_models))\n', '    if n_models == 1:\n', '        axes = [axes]\n', '    \n', '    for i, (model_name, features_dict) in enumerate(reduced_features_dict.items()):\n', '        # PCA\n', "        axes[i][0].scatter(features_dict['pca'][:, 0], features_dict['pca'][:, 1], alpha=0.6, s=20)\n", '        axes[i][0].set_title(f"PCA des features {model_name}")\n', '        axes[i][0].set_xlabel("Composante principale 1")\n', '        axes[i][0].set_ylabel("Composante principale 2")\n', '        axes[i][0].grid(True, alpha=0.3)\n', '        \n', '        # t-SNE\n', "        axes[i][1].scatter(features_dict['tsne'][:, 0], features_dict['tsne'][:, 1], alpha=0.6, s=20)\n", '        axes[i][1].set_title(f"t-SNE des features {model_name}")\n', '        axes[i][1].set_xlabel("t-SNE dimension 1")\n', '        axes[i][1].set_ylabel("t-SNE dimension 2")\n', '        axes[i][1].grid(True, alpha=0.3)\n', '    \n', '    plt.tight_layout()\n', '    plt.show()\n', '\n', '# Visualisation\n', 'visualize_features(reduced_features_dict)']}, {'cell_type': 'markdown', 'metadata': {}, 'source': ['## 6. Analyse de similarité']}, {'cell_type': 'code', 'execution_count': None, 'metadata': {}, 'outputs': [], 'source': ["# Fonction pour l'analyse de similarité\n", 'def analyze_similarity(features, model_name):\n', '    """\n', '    Analyse la similarité entre les images.\n', '    """\n', '    print(f"\\n=== Analyse de similarité pour {model_name} ===")\n', '    \n', '    # Calcul de la matrice de similarité cosinus\n', '    similarity_matrix = cosine_similarity(features)\n', '    \n', '    # Visualisation de la matrice de similarité\n', '    plt.figure(figsize=(10, 8))\n', "    plt.imshow(similarity_matrix, cmap='viridis', aspect='auto')\n", "    plt.colorbar(label='Similarité cosinus')\n", "    plt.title(f'Matrice de similarité entre images ({model_name})')\n", "    plt.xlabel('Index image')\n", "    plt.ylabel('Index image')\n", '    plt.show()\n', '    \n', '    # Statistiques de similarité\n', '    similarity_values = similarity_matrix[np.triu_indices_from(similarity_matrix, k=1)]\n', '    print(f"Moyenne: {similarity_values.mean():.3f}")\n', '    print(f"Écart-type: {similarity_values.std():.3f}")\n', '    print(f"Min: {similarity_values.min():.3f}")\n', '    print(f"Max: {similarity_values.max():.3f}")\n', '    \n', '    # Distribution de la similarité\n', '    plt.figure(figsize=(10, 6))\n', "    plt.hist(similarity_values, bins=50, alpha=0.7, color='skyblue', edgecolor='black')\n", "    plt.xlabel('Similarité cosinus')\n", "    plt.ylabel('Fréquence')\n", "    plt.title(f'Distribution de la similarité cosinus ({model_name})')\n", '    plt.grid(True, alpha=0.3)\n', '    plt.show()\n', '    \n', '    return similarity_matrix, similarity_values\n', '\n', '# Analyse de similarité pour chaque modèle\n', 'similarity_dict = {}\n', 'for model_name, features in features_dict.items():\n', '    similarity_matrix, similarity_values = analyze_similarity(features, model_name)\n', '    similarity_dict[model_name] = {\n', "        'matrix': similarity_matrix,\n", "        'values': similarity_values\n", '    }']}, {'cell_type': 'markdown', 'metadata': {}, 'source': ['## 7. Comparaison des modèles']}, {'cell_type': 'code', 'execution_count': None, 'metadata': {}, 'outputs': [], 'source': ['# Fonction pour comparer les modèles\n', 'def compare_models(features_dict, similarity_dict):\n', '    """\n', "    Compare les différents modèles d'extraction de features.\n", '    """\n', '    print("\\n=== Comparaison des modèles ===")\n', '    \n', '    # Préparer les données de comparaison\n', '    comparison_data = []\n', '    for model_name in features_dict.keys():\n', '        features = features_dict[model_name]\n', "        similarity_values = similarity_dict[model_name]['values']\n", '        \n', '        comparison_data.append({\n', "            'Model': model_name.upper(),\n", "            'Feature_Dim': features.shape[1],\n", "            'Mean_Similarity': similarity_values.mean(),\n", "            'Std_Similarity': similarity_values.std(),\n", "            'Min_Similarity': similarity_values.min(),\n", "            'Max_Similarity': similarity_values.max()\n", '        })\n', '    \n', '    # Créer un DataFrame pour la comparaison\n', '    comparison_df = pd.DataFrame(comparison_data)\n', '    \n', '    # Visualisation de la comparaison\n', '    fig, axes = plt.subplots(2, 2, figsize=(15, 12))\n', '    \n', '    # Dimensions des features\n', "    axes[0, 0].bar(comparison_df['Model'], comparison_df['Feature_Dim'], color='skyblue')\n", "    axes[0, 0].set_title('Dimensions des features')\n", "    axes[0, 0].set_ylabel('Dimension')\n", "    axes[0, 0].tick_params(axis='x', rotation=45)\n", '    \n', '    # Similarité moyenne\n', "    axes[0, 1].bar(comparison_df['Model'], comparison_df['Mean_Similarity'], color='lightcoral')\n", "    axes[0, 1].set_title('Similarité moyenne')\n", "    axes[0, 1].set_ylabel('Similarité cosinus')\n", "    axes[0, 1].tick_params(axis='x', rotation=45)\n", '    \n', '    # Écart-type de la similarité\n', "    axes[1, 0].bar(comparison_df['Model'], comparison_df['Std_Similarity'], color='lightgreen')\n", "    axes[1, 0].set_title('Écart-type de la similarité')\n", "    axes[1, 0].set_ylabel('Écart-type')\n", "    axes[1, 0].tick_params(axis='x', rotation=45)\n", '    \n', '    # Similarité maximale\n', "    axes[1, 1].bar(comparison_df['Model'], comparison_df['Max_Similarity'], color='orange')\n", "    axes[1, 1].set_title('Similarité maximale')\n", "    axes[1, 1].set_ylabel('Similarité cosinus')\n", "    axes[1, 1].tick_params(axis='x', rotation=45)\n", '    \n', '    plt.tight_layout()\n', '    plt.show()\n', '    \n', '    # Afficher le tableau de comparaison\n', '    print("Comparaison des modèles:")\n', '    print(comparison_df.to_string(index=False))\n', '    \n', '    return comparison_df\n', '\n', '# Comparaison des modèles\n', 'comparison_df = compare_models(features_dict, similarity_dict)']}, {'cell_type': 'markdown', 'metadata': {}, 'source': ['## 8. Clustering et évaluation']}, {'cell_type': 'code', 'execution_count': None, 'metadata': {}, 'outputs': [], 'source': ["# Fonction pour le clustering et l'évaluation\n", 'def cluster_and_evaluate(features, model_name, true_labels=None):\n', '    """\n', '    Applique le clustering et évalue les résultats.\n', '    """\n', '    print(f"\\n=== Clustering et évaluation pour {model_name} ===")\n', '    \n', '    # Standardisation\n', '    scaler = StandardScaler()\n', '    features_scaled = scaler.fit_transform(features)\n', '    \n', '    # Réduction de dimensionnalité avec PCA\n', '    pca = PCA(n_components=min(50, features_scaled.shape[1]), random_state=42)\n', '    features_pca = pca.fit_transform(features_scaled)\n', '    print(f"Variance expliquée par PCA: {pca.explained_variance_ratio_.sum():.2%}")\n', '    \n', '    # Clustering avec K-Means\n', '    kmeans = KMeans(n_clusters=2, random_state=42, n_init=10)\n', '    cluster_labels = kmeans.fit_predict(features_pca)\n', '    \n', '    # Évaluation\n', '    silhouette = silhouette_score(features_pca, cluster_labels)\n', '    davies_bouldin = davies_bouldin_score(features_pca, cluster_labels)\n', '    \n', '    print(f"Silhouette Score: {silhouette:.4f}")\n', '    print(f"Davies-Bouldin Index: {davies_bouldin:.4f}")\n', '    \n', '    # ARI si les vrais labels sont disponibles\n', '    if true_labels is not None:\n', '        # Filtrer les labels non définis (-1)\n', '        valid_indices = [i for i, label in enumerate(true_labels) if label != -1]\n', '        if len(valid_indices) > 1:\n', '            valid_cluster_labels = [cluster_labels[i] for i in valid_indices]\n', '            valid_true_labels = [true_labels[i] for i in valid_indices]\n', '            ari = adjusted_rand_score(valid_true_labels, valid_cluster_labels)\n', '            print(f"Adjusted Rand Index: {ari:.4f}")\n', '    \n', '    # Visualisation des clusters\n', '    plt.figure(figsize=(10, 8))\n', '    scatter = plt.scatter(features_pca[:, 0], features_pca[:, 1], \n', "                         c=cluster_labels, cmap='viridis', alpha=0.6)\n", '    plt.colorbar(scatter)\n', '    plt.title(f"Clusters ({model_name})")\n', '    plt.xlabel("Composante principale 1")\n', '    plt.ylabel("Composante principale 2")\n', '    plt.grid(True, alpha=0.3)\n', '    plt.show()\n', '    \n', '    return {\n', "        'labels': cluster_labels,\n", "        'silhouette': silhouette,\n", "        'davies_bouldin': davies_bouldin,\n", "        'features_pca': features_pca\n", '    }\n', '\n', '# Charger les vrais labels si disponibles\n', 'def load_true_labels(image_paths):\n', '    """\n', "    Charge les vrais labels à partir des chemins d'images.\n", '    """\n', '    true_labels = []\n', '    for path in image_paths:\n', '        if "normal" in str(path):\n', '            true_labels.append(0)  # Normal\n', '        elif "cancer" in str(path):\n', '            true_labels.append(1)  # Cancer\n', '        else:\n', '            true_labels.append(-1)  # Sans label\n', '    \n', '    return true_labels\n', '\n', '# Charger les vrais labels\n', 'true_labels = load_true_labels(image_paths)\n', 'print(f"Labels chargés: {len([l for l in true_labels if l != -1])} avec label, {len([l for l in true_labels if l == -1])} sans label")']}, {'cell_type': 'code', 'execution_count': None, 'metadata': {}, 'outputs': [], 'source': ['# Clustering et évaluation pour chaque modèle\n', 'clustering_results = {}\n', 'for model_name, features in features_dict.items():\n', '    clustering_results[model_name] = cluster_and_evaluate(features, model_name, true_labels)']}, {'cell_type': 'markdown', 'metadata': {}, 'source': ['## 9. Comparaison des performances de clustering']}, {'cell_type': 'code', 'execution_count': None, 'metadata': {}, 'outputs': [], 'source': ['# Fonction pour comparer les performances de clustering\n', 'def compare_clustering_performance(clustering_results):\n', '    """\n', '    Compare les performances de clustering entre les modèles.\n', '    """\n', '    print("\\n=== Comparaison des performances de clustering ===")\n', '    \n', '    # Préparer les données de comparaison\n', '    comparison_data = []\n', '    for model_name, results in clustering_results.items():\n', '        comparison_data.append({\n', "            'Model': model_name.upper(),\n", "            'Silhouette_Score': results['silhouette'],\n", "            'Davies_Bouldin_Index': results['davies_bouldin']\n", '        })\n', '    \n', '    # Créer un DataFrame pour la comparaison\n', '    comparison_df = pd.DataFrame(comparison_data)\n', '    \n', '    # Visualisation de la comparaison\n', '    fig, axes = plt.subplots(1, 2, figsize=(15, 6))\n', '    \n', '    # Silhouette Score\n', "    axes[0].bar(comparison_df['Model'], comparison_df['Silhouette_Score'], color='skyblue')\n", "    axes[0].set_title('Silhouette Score Comparison')\n", "    axes[0].set_ylabel('Silhouette Score')\n", "    axes[0].tick_params(axis='x', rotation=45)\n", '    \n', '    # Davies-Bouldin Index\n', "    axes[1].bar(comparison_df['Model'], comparison_df['Davies_Bouldin_Index'], color='lightcoral')\n", "    axes[1].set_title('Davies-Bouldin Index Comparison')\n", "    axes[1].set_ylabel('Davies-Bouldin Index')\n", "    axes[1].tick_params(axis='x', rotation=45)\n", '    \n', '    plt.tight_layout()\n', '    plt.show()\n', '    \n', '    # Afficher le tableau de comparaison\n', '    print("Comparaison des performances de clustering:")\n', '    print(comparison_df.to_string(index=False))\n', '    \n', '    return comparison_df\n', '\n', '# Comparaison des performances de clustering\n', 'clustering_comparison_df = compare_clustering_performance(clustering_results)']}, {'cell_type': 'markdown', 'metadata': {}, 'source': ['## 10. Résumé et conclusions']}, {'cell_type': 'code', 'execution_count': None, 'metadata': {}, 'outputs': [], 'source': ['print("\\n=== RÉSUMÉ DE L\'EXTRACTION DE FEATURES ===")\n', 'for model_name, features in features_dict.items():\n', '    print(f"\\n{model_name.upper()}:")\n', '    print(f"  Nombre d\'images traitées: {len(image_paths)}")\n', '    print(f"  Dimension des features: {features.shape[1]}")\n', '    print(f"  Similarité moyenne entre images: {similarity_dict[model_name][\'values\'].mean():.3f}")\n', '    print(f"  Silhouette Score: {clustering_results[model_name][\'silhouette\']:.4f}")\n', '    print(f"  Davies-Bouldin Index: {clustering_results[model_name][\'davies_bouldin\']:.4f}")\n', '\n', 'print("\\n=== CONCLUSIONS ===")\n', "best_model = clustering_comparison_df.loc[clustering_comparison_df['Silhouette_Score'].idxmax(), 'Model']\n", 'print(f"Meilleur modèle selon le Silhouette Score: {best_model}")\n', '\n', "best_model_db = clustering_comparison_df.loc[clustering_comparison_df['Davies_Bouldin_Index'].idxmin(), 'Model']\n", 'print(f"Meilleur modèle selon le Davies-Bouldin Index: {best_model_db}")\n', '\n', 'print("\\nProchaines étapes:")\n', 'print("1. Utiliser le meilleur modèle pour la génération de labels faibles")\n', 'print("2. Appliquer le clustering avec différents nombres de clusters")\n', 'print("3. Visualiser les clusters dans l\'espace réduit")\n', 'print("4. Évaluer la qualité du clustering avec métriques supplémentaires")']}, {'cell_type': 'markdown', 'metadata': {}, 'source': ['## 11. Sauvegarde des résultats finaux']}, {'cell_type': 'code', 'execution_count': None, 'metadata': {}, 'outputs': [], 'source': ['# Sauvegarde des résultats complets\n', 'import pickle\n', '\n', 'final_results = {\n', "    'features': features_dict,\n", "    'reduced_features': reduced_features_dict,\n", "    'simi