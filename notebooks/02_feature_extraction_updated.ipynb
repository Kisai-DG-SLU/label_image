{'cells': [{'cell_type': 'markdown', 'metadata': {}, 'source': ['# Notebook 02: Feature Extraction avec ResNet', '\\n', "Ce notebook démontre l'extraction de features à partir d'images IRM cérébrales en utilisant différents modèles pré-entraînés.", '\\n', '## Objectifs', '1. Charger et pré-traiter les images IRM', '2. Extraire des features avec ResNet50, VGG16 et DenseNet', '3. Visualiser les embeddings dans un espace réduit', '4. Préparer les données pour le clustering', '5. Comparer les performances des différents modèles']}, {'cell_type': 'code', 'execution_count': 'None', 'metadata': {}, 'outputs': [], 'source': ['# Importations', 'import sys', 'import os', "sys.path.append('..')", '\\n', 'import numpy as np', 'import pandas as pd', 'import matplotlib.pyplot as plt', 'import seaborn as sns', 'from pathlib import Path', 'import torch', 'import torchvision.transforms as transforms', 'import torchvision.models as models', 'from PIL import Image', 'import random', 'import warnings', "warnings.filterwarnings('ignore')", '\\n', '# Scikit-learn', 'from sklearn.decomposition import PCA', 'from sklearn.manifold import TSNE', 'from sklearn.metrics.pairwise import cosine_similarity', 'from sklearn.preprocessing import StandardScaler', 'from sklearn.cluster import KMeans', 'from sklearn.metrics import silhouette_score, davies_bouldin_score, adjusted_rand_score', '\\n', '# Visualisation', 'import plotly.express as px', 'import plotly.graph_objects as go', 'from plotly.subplots import make_subplots', '\\n', '# Configuration', "DATA_DIR = Path('../data')", "RESULTS_DIR = Path('../results')", 'RESULTS_DIR.mkdir(exist_ok=True)', '\\n', "DEVICE = 'cuda' if torch.cuda.is_available() else 'cpu'", 'BATCH_SIZE = 32', '\\n', "print(f'Device: {DEVICE}')", "print(f'Data directory: {DATA_DIR}')", "print(f'Results directory: {RESULTS_DIR}')"]}, {'cell_type': 'markdown', 'metadata': {}, 'source': ['## 1. Configuration et chargement des données']}, {'cell_type': 'code', 'execution_count': 'None', 'metadata': {}, 'outputs': [], 'source': ['# Fonction pour charger les images', '\\n', 'def load_image_paths(data_dir, max_images=None):', "    '''", '    Charge les chemins des images depuis les répertoires data/avec_labels et data/sans_label.', "    '''", '    image_paths = []'], '    # Chargement des images avec labels': "    normal_dir = data_dir / 'avec_labels' / 'normal'", "    cancer_dir = data_dir / 'avec_labels' / 'cancer'": '', '    if normal_dir.exists():': "        normal_images = list(normal_dir.glob('*.jpg'))", '        image_paths.extend(normal_images)': "        print(f'Chargé {len(normal_images)} images normales')", '    if cancer_dir.exists():': "        cancer_images = list(cancer_dir.glob('*.jpg'))", '        image_paths.extend(cancer_images)': "        print(f'Chargé {len(cancer_images)} images avec cancer')", '    # Chargement des images sans labels': "    sans_label_dir = data_dir / 'sans_label'", '    if sans_label_dir.exists():': "        sans_label_images = list(sans_label_dir.glob('*.jpg'))", '        image_paths.extend(sans_label_images)': "        print(f'Chargé {len(sans_label_images)} images sans label')", '    # Limiter à un sous-ensemble si nécessaire': '    if max_images and len(image_paths) > max_images:', '        import random': '        image_paths = random.sample(image_paths, max_images)', "        print(f'Utilisation d\\'un sous-ensemble de {len(image_paths)} images pour les tests')": '', '    return image_paths': '\\n', '# Chargement des images': 'image_paths = load_image_paths(DATA_DIR, max_images=100)', "print(f'Nombre total d\\'images chargées: {len(image_paths)}')": ''}, {'cell_type': 'code', 'execution_count': 'None', 'metadata': {}, 'outputs': [], 'source': ['# Transformations pour les modèles pré-entraînés', 'transform = transforms.Compose([', "    transforms.Resize((224, 224)),  # Taille d'entrée standard", '    transforms.ToTensor(),', '    transforms.Normalize(mean=[0.485, 0.456, 0.406],  # ImageNet stats', '                         std=[0.229, 0.224, 0.225])', '])', '\\n', '# Dataset personnalisé pour les IRM', 'class MRIDataset(torch.utils.data.Dataset):', '    def __init__(self, image_paths, transform=None):', '        self.image_paths = image_paths', '        self.transform = transform'], '    def __len__(self):': '        return len(self.image_paths)', '    def __getitem__(self, idx):': "        # Charger l'image", '        image_path = self.image_paths[idx]': "        image = Image.open(image_path).convert('RGB')", '        if self.transform:': '            image = self.transform(image)', '        return image': '', '# Création du dataset personnalisé pour les IRM': 'class MRIDataset(torch.utils.data.Dataset):', '    def __init__(self, image_paths, transform=None):': '        self.image_paths = image_paths', '        self.transform = transform': ''}, {'cell_type': 'markdown', 'metadata': {}, 'source': ['## 2. Pré-traitement des images']}, {'cell_type': 'code', 'execution_count': 'None', 'metadata': {}, 'outputs': [], 'source': ["# Classe pour l'extraction de features avec différents modèles", 'class MultiModelFeatureExtractor:', "    def __init__(self, device='cpu'):", '        self.device = device', '        self.models = {}', '        self.feature_dims = {}'], '    def load_model(self, model_name):': "        '''", "        Charge un modèle pré-entraîné et le prépare pour l'extraction de features.": "        '''", "        if model_name == 'resnet50':": '            model = models.resnet50(pretrained=True)', "            # Retirer la dernière couche pour l'extraction de features": '            feature_extractor = torch.nn.Sequential(*list(model.children())[:-1])', '            feature_dim = 2048': "        elif model_name == 'vgg16':", '            model = models.vgg16(pretrained=True)': "            # Retirer la dernière couche pour l'extraction de features", '            feature_extractor = torch.nn.Sequential(*list(model.features.children()))': "            # Ajouter l'adaptive average pooling", '            feature_extractor = torch.nn.Sequential(': '                model.features,', '                torch.nn.AdaptiveAvgPool2d((1, 1))': '            )', '            feature_dim = 512': "        elif model_name == 'densenet':", '            model = models.densenet121(pretrained=True)': "            # Retirer le classifieur pour l'extraction de features", '                torch.nn.ReLU(inplace=True),': '                torch.nn.AdaptiveAvgPool2d((1, 1))', '            )': '            feature_dim = 1024', '        else:': "            raise ValueError(f'Modèle non supporté: {model_name}')", '        feature_extractor = feature_extractor.to(self.device)': '        feature_extractor.eval()', '        self.models[model_name] = feature_extractor': '        self.feature_dims[model_name] = feature_dim', "        print(f'Modèle {model_name} chargé avec dimension de features: {feature_dim}')": '', '    def extract_features(self, model_name, images):': "        '''", "        Extrait les features d'un batch d'images avec un modèle spécifique.": "        '''", '        if model_name not in self.models:': '            self.load_model(model_name)', '        model = self.models[model_name]': '', '        with torch.no_grad():': '            for batch in dataloader:', '            features = model(images)': '            features = features.view(features.size(0), -1)', '            return features.cpu().numpy()': '', '    def extract_features_from_dataset(self, model_name, dataset, batch_size=32):': "        '''", '        Extrait les features de tout le dataset avec un modèle spécifique.': "        '''", '        dataloader = torch.utils.data.DataLoader(dataset, batch_size=batch_size, shuffle=False)': '        all_features = []', '                batch_features = self.extract_features(model_name, batch)': '                all_features.append(batch_features)', '        return np.vstack(all_features)': '\\n', "# Initialisation de l'extracteur de features": 'feature_extractor = MultiModelFeatureExtractor(device=DEVICE)', "print('Extracteur de features initialisé')": '\\n', '# Création du dataset': 'dataset = MRIDataset(image_paths, transform=transform)', "print(f'Dataset créé avec {len(dataset)} images')": ''}, {'cell_type': 'code', 'execution_count': 'None', 'metadata': {}, 'outputs': [], 'source': ['# Extraction des features avec différents modèles', "models_to_test = ['resnet50', 'vgg16', 'densenet']", 'features_dict = {}', '\\n', "print('Début de l\\'extraction des features...')", 'for model_name in models_to_test:', "    print(f'Extraction des features avec {model_name}...')", '    features = feature_extractor.extract_features_from_dataset(model_name, dataset, BATCH_SIZE)', '    features_dict[model_name] = features', "    print(f'Shape des features {model_name}: {features.shape}')"], '    # Sauvegarde des features': "    features_path = RESULTS_DIR / f'features_{model_name}.npy'", '    np.save(features_path, features)': "    print(f'Features {model_name} sauvegardées dans: {features_path}')", "print('Extraction des features terminée')": ''}, {'cell_type': 'markdown', 'metadata': {}, 'source': ['## 3. Analyse statistique des features']}, {'cell_type': 'markdown', 'execution_count': 'None', 'metadata': {}, 'outputs': [], 'source': ['## 4. Réduction de dimensionnalité pour visualisation'], '    # Statistiques descriptives': '    features_df = pd.DataFrame(features)', "    stats = features_df.describe().T[['mean', 'std', 'min', 'max']]": '', '    print(f\'Moyenne globale: {stats["mean"].mean():.4f}\')': '    print(f\'Écart-type moyen: {stats["std"].mean():.4f}\')', '    print(f\'Valeur min globale: {stats["min"].min():.4f}\')': '    print(f\'Valeur max globale: {stats["max"].max():.4f}\')', '    # Distribution des statistiques': '    fig, axes = plt.subplots(2, 2, figsize=(12, 10))', "    axes[0, 0].hist(stats['mean'], bins=30, alpha=0.7, color='skyblue', edgecolor='black')": "    axes[0, 0].set_title(f'Distribution des moyennes ({model_name})')", "    axes[0, 0].set_xlabel('Moyenne')": "    axes[0, 0].set_ylabel('Fréquence')", "    axes[0, 1].hist(stats['std'], bins=30, alpha=0.7, color='lightcoral', edgecolor='black')": "    axes[0, 1].set_title(f'Distribution des écarts-types ({model_name})')", "    axes[0, 1].set_xlabel('Écart-type')": "    axes[0, 1].set_ylabel('Fréquence')", "    axes[1, 0].hist(stats['min'], bins=30, alpha=0.7, color='lightgreen', edgecolor='black')": "    axes[1, 0].set_title(f'Distribution des minimums ({model_name})')", "    axes[1, 0].set_xlabel('Minimum')": "    axes[1, 0].set_ylabel('Fréquence')", "    axes[1, 1].hist(stats['max'], bins=30, alpha=0.7, color='orange', edgecolor='black')": "    axes[1, 1].set_title(f'Distribution des maximums ({model_name})')", "    axes[1, 1].set_xlabel('Maximum')": "    axes[1, 1].set_ylabel('Fréquence')", '    plt.tight_layout()': '    plt.show()', '    return stats': '\\n', '# Analyse des features pour chaque modèle': 'stats_dict = {}', 'for model_name, features in features_dict.items():': '    stats_dict[model_name] = analyze_features(features, model_name)'}, {'cell_type': 'code', 'execution_count': 'None', 'metadata': {}, 'outputs': [], 'source': ['# Visualisation des features réduites', 'def visualize_features(reduced_features_dict):', "    '''", '    Visualise les features réduites pour tous les modèles.', "    '''", '    n_models = len(reduced_features_dict)'], "    if method == 'pca':": "        print(f'Variance expliquée par PCA: {reducer.explained_variance_ratio_.sum():.2%}')", "    elif method == 'tsne':": '        reducer = TSNE(n_components=n_components, random_state=42, perplexity=min(30, len(features)-1))', '    else:': "        raise ValueError(f'Méthode non supportée: {method}')", '    reduced_features = reducer.fit_transform(features_scaled)': '', '    return reduced_features, reducer': '\\n', '# Réduction de dimensionnalité pour chaque modèle': 'reduced_features_dict = {}', 'for model_name, features in features_dict.items():': "    print(f'\\nRéduction de dimensionnalité pour {model_name}...')", '    # PCA': "    features_pca, pca = reduce_dimensions(features, method='pca', n_components=2)", '    # t-SNE': "    features_tsne, tsne = reduce_dimensions(features, method='tsne', n_components=2)", '    reduced_features_dict[model_name] = {': "        'pca': features_pca,", "        'tsne': features_tsne,": "        'pca_model': pca,", "        'tsne_model': tsne": '    }', '    # Visualisation PCA': '    fig, axes = plt.subplots(n_models, 2, figsize=(15, 5*n_models))', '    if n_models == 1:': '        axes = [axes]', '    for i, (model_name, features_dict) in enumerate(reduced_features_dict.items()):': '        # PCA', "        axes[i][0].scatter(features_dict['pca'][:, 0], features_dict['pca'][:, 1], alpha=0.6, s=20)": "        axes[i][0].set_title(f'PCA des features {model_name}')", "        axes[i][0].set_xlabel('Composante principale 1')": "        axes[i][0].set_ylabel('Composante principale 2')", '        axes[i][0].grid(True, alpha=0.3)': '', '        # t-SNE': "        axes[i][1].scatter(features_dict['tsne'][:, 0], features_dict['tsne'][:, 1], alpha=0.6, s=20)", "        axes[i][1].set_title(f't-SNE des features {model_name}')": "        axes[i][1].set_xlabel('t-SNE dimension 1')", "        axes[i][1].set_ylabel('t-SNE dimension 2')": '        axes[i][1].grid(True, alpha=0.3)', '    plt.tight_layout()': '    plt.show()', '\\n': '# Visualisation', 'visualize_features(reduced_features_dict)': ''}, {'cell_type': 'markdown', 'metadata': {}, 'source': ['## 5. Analyse de similarité']}, {'cell_type': 'markdown', 'execution_count': 'None', 'metadata': {}, 'outputs': [], 'source': ['## 6. Comparaison des modèles'], '    # Calcul de la matrice de similarité cosinus': '    similarity_matrix = cosine_similarity(features)', '    # Visualisation de la matrice de similarité': '    plt.figure(figsize=(10, 8))', "    plt.imshow(similarity_matrix, cmap='viridis', aspect='auto')": "    plt.colorbar(label='Similarité cosinus')", "    plt.title(f'Matrice de similarité entre images ({model_name})')": "    plt.xlabel('Index image')", "    plt.ylabel('Index image')": '    plt.show()', '    # Statistiques de similarité': '    similarity_values = similarity_matrix[np.triu_indices_from(similarity_matrix, k=1)]', "    print(f'Moyenne: {similarity_values.mean():.3f}')": "    print(f'Écart-type: {similarity_values.std():.3f}')", "    print(f'Min: {similarity_values.min():.3f}')": "    print(f'Max: {similarity_values.max():.3f}')", '    # Distribution de la similarité': '    plt.figure(figsize=(10, 6))', "    plt.hist(similarity_values, bins=50, alpha=0.7, color='skyblue', edgecolor='black')": "    plt.xlabel('Similarité cosinus')", "    plt.ylabel('Fréquence')": "    plt.title(f'Distribution de la similarité cosinus ({model_name})')", '    plt.grid(True, alpha=0.3)': '    plt.show()', '    return similarity_matrix, similarity_values': '\\n', '# Analyse de similarité pour chaque modèle': 'similarity_dict = {}', 'for model_name, features in features_dict.items():': '    similarity_matrix, similarity_values = analyze_similarity(features, model_name)', '    similarity_dict[model_name] = {': "        'matrix': similarity_matrix,", "        'values': similarity_values": '    }'}, {'cell_type': 'markdown', 'execution_count': 'None', 'metadata': {}, 'outputs': [], 'source': ['## 7. Clustering et évaluation'], '    # Préparer les données de comparaison': '    comparison_data = []', '    for model_name in features_dict.keys():': '        features = features_dict[model_name]', "        similarity_values = similarity_dict[model_name]['values']": '', '        comparison_data.append({': "            'Model': model_name.upper(),", "            'Feature_Dim': features.shape[1],": "            'Mean_Similarity': similarity_values.mean(),", "            'Std_Similarity': similarity_values.std(),": "            'Min_Similarity': similarity_values.min(),", "            'Max_Similarity': similarity_values.max()": '        })', '    # Créer un DataFrame pour la comparaison': '    comparison_df = pd.DataFrame(comparison_data)', '    # Visualisation de la comparaison': '    fig, axes = plt.subplots(2, 2, figsize=(15, 12))', '    # Dimensions des features': "    axes[0, 0].bar(comparison_df['Model'], comparison_df['Feature_Dim'], color='skyblue')", "    axes[0, 0].set_title('Dimensions des features')": "    axes[0, 0].set_ylabel('Dimension')", "    axes[0, 0].tick_params(axis='x', rotation=45)": '', '    # Similarité moyenne': "    axes[0, 1].bar(comparison_df['Model'], comparison_df['Mean_Similarity'], color='lightcoral')", "    axes[0, 1].set_title('Similarité moyenne')": "    axes[0, 1].set_ylabel('Similarité cosinus')", "    axes[0, 1].tick_params(axis='x', rotation=45)": '', '    # Écart-type de la similarité': "    axes[1, 0].bar(comparison_df['Model'], comparison_df['Std_Similarity'], color='lightgreen')", "    axes[1, 0].set_title('Écart-type de la similarité')": "    axes[1, 0].set_ylabel('Écart-type')", "    axes[1, 0].tick_params(axis='x', rotation=45)": '', '    # Similarité maximale': "    axes[1, 1].bar(comparison_df['Model'], comparison_df['Max_Similarity'], color='orange')", "    axes[1, 1].set_title('Similarité maximale')": "    axes[1, 1].set_ylabel('Similarité cosinus')", "    axes[1, 1].tick_params(axis='x', rotation=45)": '', '    plt.tight_layout()': '    plt.show()', '    # Afficher le tableau de comparaison': "    print('Comparaison des modèles:')", '    print(comparison_df.to_string(index=False))': '', '    return comparison_df': '\\n', '# Comparaison des modèles': 'comparison_df = compare_models(features_dict, similarity_dict)'}, {'cell_type': 'code', 'execution_count': 'None', 'metadata': {}, 'outputs': [], 'source': ["# Fonction pour le clustering et l'évaluation", 'def cluster_and_evaluate(features, model_name, true_labels=None):', "    '''", '    Applique le clustering et évalue les résultats.', "    '''", "    print(f'\\n=== Clustering et évaluation pour {model_name} ===')"], '    # Standardisation': '    scaler = StandardScaler()', '    features_scaled = scaler.fit_transform(features)': '', '    # Réduction de dimensionnalité avec PCA': '    pca = PCA(n_components=min(50, features_scaled.shape[1]), random_state=42)', '    features_pca = pca.fit_transform(features_scaled)': "    print(f'Variance expliquée par PCA: {pca.explained_variance_ratio_.sum():.2%}')", '    # Clustering avec K-Means': '    kmeans = KMeans(n_clusters=2, random_state=42, n_init=10)', '    cluster_labels = kmeans.fit_predict(features_pca)': '', '    # Évaluation': '    silhouette = silhouette_score(features_pca, cluster_labels)', '    davies_bouldin = davies_bouldin_score(features_pca, cluster_labels)': '', "    print(f'Silhouette Score: {silhouette:.4f}')": "    print(f'Davies-Bouldin Index: {davies_bouldin:.4f}')", '    # ARI si les vrais labels sont disponibles': '    if true_labels is not None:', '        # Filtrer les labels non définis (-1)': '        valid_indices = [i for i, label in enumerate(true_labels) if label != -1]', '        if len(valid_indices) > 1:': '            valid_cluster_labels = [cluster_labels[i] for i in valid_indices]', '            valid_true_labels = [true_labels[i] for i in valid_indices]': '            ari = adjusted_rand_score(valid_true_labels, valid_cluster_labels)', "            print(f'Adjusted Rand Index: {ari:.4f}')": '', '    # Visualisation des clusters': '    plt.figure(figsize=(10, 8))', '    scatter = plt.scatter(features_pca[:, 0], features_pca[:, 1],': "                         c=cluster_labels, cmap='viridis', alpha=0.6)", '    plt.colorbar(scatter)': "    plt.title(f'Clusters ({model_name})'))", "    plt.xlabel('Composante principale 1')": "    plt.ylabel('Composante principale 2')", '    plt.grid(True, alpha=0.3)': '    plt.show()', '    return {': "        'labels': cluster_labels,", "        'silhouette': silhouette,